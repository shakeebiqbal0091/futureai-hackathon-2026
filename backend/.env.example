# Environment Variables for WorkForce Intelligence Agent
# Copy this file to .env and fill in the actual values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# CORS Configuration
CORS_ORIGINS=*

# Anthropic API Configuration (Get your key from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# FTE Analysis Defaults
DEFAULT_FTE_HOURS_PER_DAY=8
DEFAULT_WORKING_DAYS_PER_YEAR=250
DEFAULT_HOURLY_COST=50.0

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Chart Configuration
CHART_DPI=300
CHART_FORMAT=png

# Logging Configuration
LOG_LEVEL=INFO